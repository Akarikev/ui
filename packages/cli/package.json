{
  "name": "elorm",
  "version": "0.2.2",
  "description": "CLI for elorm/ui — copy-paste React component library",
  "type": "module",
  "bin": {
    "elorm": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:deps": "npm run build --prefix ../schema && npm run build --prefix ../themes",
    "build": "tsup && chmod +x dist/index.js",
    "prepublishOnly": "npm run build:deps && npm run build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.0",
    "cosmiconfig": "^9.0.0",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.3",
    "picocolors": "^1.1.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@elorm/schema": "workspace:*",
    "@elorm/themes": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.15.32",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Akarikev/ui.git",
    "directory": "packages/cli"
  },
  "homepage": "https://ui.elorm.xyz",
  "bugs": {
    "url": "https://github.com/Akarikev/ui/issues"
  },
  "keywords": [
    "elorm",
    "ui",
    "components",
    "react",
    "tailwind",
    "cli",
    "shadcn",
    "base-ui",
    "radix",
    "heroui"
  ],
  "license": "MIT"
}
