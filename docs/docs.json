              "components/select",
              "components/dialog",
              "components/sheet",
              "components/dropdown-menu",
              "components/tooltip",
              "components/card",
              "components/badge",
              "components/separator",
              "components/skeleton"
            ]
          },
          {
            "group": "Blocks",
            "pages": [
              "components/empty-state",
              "components/stat-card",
              "components/page-header"
            ]
          }
        ]
      }
    ]
  },
  "footerSocials": {
    "github": "https://github.com/Akarikev/elorm-ui"
