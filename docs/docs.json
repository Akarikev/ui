{
  "$schema": "https://mintlify.com/docs.json",
  "name": "elorm/ui",
  "theme": "mint",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "topbarLinks": [
    {
      "name": "GitHub",
