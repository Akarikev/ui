{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "elorm/ui configuration",
  "description": "Configuration for elorm/ui projects",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "style": { "type": "string", "enum": ["elorm"], "default": "elorm" },
    "uiLibrary": {
      "type": "string",
      "enum": ["base-ui", "radix"],
      "default": "base-ui"
    },
    "rsc": { "type": "boolean", "default": true },
    "tsx": { "type": "boolean", "default": true },
    "tailwind": {
      "type": "object",
      "properties": {
        "config": { "type": "string" },
        "css": { "type": "string" },
        "baseColor": {
          "type": "string",
          "enum": ["neutral", "zinc", "slate", "stone", "gray"],
          "default": "neutral"
        },
        "cssVariables": { "type": "boolean", "default": true }
      },
      "required": ["css"]
    },
    "aliases": {
      "type": "object",
      "properties": {
        "components": { "type": "string" },
        "utils": { "type": "string" },
        "ui": { "type": "string" },
        "lib": { "type": "string" },
        "hooks": { "type": "string" }
      },
      "required": ["components", "utils", "ui", "lib"]
    },
    "iconLibrary": { "type": "string", "default": "lucide" },
    "registries": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "default": {
        "@elorm": "https://ui.elorm.xyz/r/{library}/{name}.json"
      }
    },
    "framework": {
      "type": "string",
      "enum": ["next", "vite", "react-router", "astro"],
      "default": "next"
    },
    "theme": {
      "type": "object",
      "properties": {
        "accent": {
          "type": "string",
          "enum": [
            "default",
            "mono",
            "blue",
            "violet",
            "green",
            "orange",
            "rose",
            "amber",
            "cyan"
          ],
          "default": "default"
        },
        "radius": {
          "type": "string",
          "enum": ["default", "compact", "round"],
          "default": "default"
        }
      }
    }
  }
}
