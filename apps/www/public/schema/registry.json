{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "elorm/ui registry",
  "description": "Registry index for elorm/ui components, blocks, and themes",
  "type": "object",
  "required": ["name", "homepage", "items"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string" },
    "homepage": { "type": "string", "format": "uri" },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/registryItem" }
    }
  },
  "$defs": {
    "registryFile": {
      "type": "object",
      "required": ["path", "type"],
      "properties": {
        "path": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "registry:ui",
            "registry:component",
            "registry:block",
            "registry:hook",
            "registry:lib",
            "registry:theme",
            "registry:style",
            "registry:file",
            "registry:page",
            "registry:item"
          ]
        },
        "target": { "type": "string" },
        "content": { "type": "string" }
      }
    },
    "registryItem": {
      "type": "object",
      "required": ["name", "type", "files"],
      "properties": {
        "$schema": { "type": "string" },
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "registry:ui",
            "registry:component",
            "registry:block",
            "registry:hook",
            "registry:lib",
            "registry:theme",
            "registry:style",
            "registry:file",
            "registry:page",
            "registry:item"
          ]
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "devDependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "registryDependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "files": {
          "type": "array",
          "items": { "$ref": "#/$defs/registryFile" }
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "docs": { "type": "string" }
      }
    }
  }
}
