{"name":"settings-section","type":"registry:block","title":"Settings Section","description":"A settings page block with tabs and toggle switches.","registryDependencies":["utils","card","field","switch","tabs"],"files":[{"path":"packages/registry/blocks/settings-section.tsx","type":"registry:block","content":"\"use client\"\n\nimport * as React from \"react\"\n\nimport { cn } from \"@/lib/utils\"\nimport {\n  Card,\n  CardContent,\n  CardDescription,\n  CardHeader,\n  CardTitle,\n} from \"@/components/ui/card\"\nimport {\n  Field,\n  FieldDescription,\n  FieldGroup,\n  FieldLabel,\n} from \"@/components/ui/field\"\nimport { Switch } from \"@/components/ui/switch\"\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from \"@/components/ui/tabs\"\n\nfunction SettingsSection({\n  className,\n  ...props\n}: React.ComponentProps<\"div\">) {\n  return (\n    <div data-slot=\"settings-section\" className={cn(\"flex flex-col gap-6\", className)} {...props}>\n      <Tabs defaultValue=\"general\">\n        <TabsList>\n          <TabsTrigger value=\"general\">General</TabsTrigger>\n          <TabsTrigger value=\"notifications\">Notifications</TabsTrigger>\n          <TabsTrigger value=\"security\">Security</TabsTrigger>\n        </TabsList>\n        <TabsContent value=\"general\">\n          <Card>\n            <CardHeader>\n              <CardTitle>General settings</CardTitle>\n              <CardDescription>Manage your workspace preferences.</CardDescription>\n            </CardHeader>\n            <CardContent>\n              <FieldGroup>\n                <Field orientation=\"horizontal\">\n                  <div className=\"flex flex-1 flex-col gap-1\">\n                    <FieldLabel htmlFor=\"marketing\">Marketing emails</FieldLabel>\n                    <FieldDescription>\n                      Receive emails about new features and updates.\n                    </FieldDescription>\n                  </div>\n                  <Switch id=\"marketing\" />\n                </Field>\n                <Field orientation=\"horizontal\">\n                  <div className=\"flex flex-1 flex-col gap-1\">\n                    <FieldLabel htmlFor=\"analytics\">Usage analytics</FieldLabel>\n                    <FieldDescription>\n                      Help improve elorm/ui by sharing anonymous usage data.\n                    </FieldDescription>\n                  </div>\n                  <Switch id=\"analytics\" defaultChecked />\n                </Field>\n              </FieldGroup>\n            </CardContent>\n          </Card>\n        </TabsContent>\n        <TabsContent value=\"notifications\">\n          <Card>\n            <CardHeader>\n              <CardTitle>Notification settings</CardTitle>\n              <CardDescription>Choose what you get notified about.</CardDescription>\n            </CardHeader>\n          </Card>\n        </TabsContent>\n        <TabsContent value=\"security\">\n          <Card>\n            <CardHeader>\n              <CardTitle>Security settings</CardTitle>\n              <CardDescription>Manage authentication and access.</CardDescription>\n            </CardHeader>\n          </Card>\n        </TabsContent>\n      </Tabs>\n    </div>\n  )\n}\n\nexport { SettingsSection }\n"}],"categories":["blocks","settings"]}
