2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z\" />\n    </svg>\n  )\n}\n\nconst platformIcons: Record<\n  SocialPlatform,\n  React.ComponentType<{ className?: string }>\n> = {\n  github: GitHubIcon,\n  x: XIcon,\n  mastodon: MastodonIcon,\n  bluesky: BlueskyIcon,\n  reddit: RedditIcon,\n  discord: DiscordIcon,\n}\n\nfunction SocialLinks({ links, className, ...props }: SocialLinksProps) {\n  return (\n    <nav\n      data-slot=\"social-links\"\n      aria-label=\"Social links\"\n      className={cn(\"flex items-center gap-5\", className)}\n      {...props}\n    >\n      {links.map(({ platform, href, label }) => {\n        const Icon = platformIcons[platform]\n        const linkLabel = label ?? platformLabels[platform]\n\n        return (\n          <a\n            key={`${platform}-${href}`}\n            href={href}\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            aria-label={linkLabel}\n            className={cn(\n              \"text-muted-foreground hover:text-foreground\",\n              transitionBase\n            )}\n          >\n            <Icon className=\"size-5\" />\n          </a>\n        )\n      })}\n    </nav>\n  )\n}\n\nexport { SocialLinks, type SocialLinkItem, type SocialPlatform }\n"}],"meta":{"usage":"Pass an array of platform + href pairs. Supports github, x, mastodon, bluesky, reddit, and discord.","examples":[{"title":"Default","code":"<SocialLinks links={[{ platform: \"github\", href: \"https://github.com/you\" }]} />"}]},"categories":["ui","navigation"]}
