    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "Displays a button or a component that looks like a button.",
      "categories": ["ui", "forms"],
      "registryDependencies": ["utils", "ui-styles"],
      "dependencies": ["@base-ui/react", "class-variance-authority"],
      "files": [
        {
          "path": "packages/registry/ui/button.tsx",
          "type": "registry:ui"
        }
      ],
      "meta": {
        "usage": "Primary actions. Use variant=outline for secondary actions, variant=ghost for tertiary.",
        "composition": ["DialogFooter", "CardFooter"],
        "antiPatterns": ["Do not use raw bg-blue-500", "Do not nest buttons inside buttons"],
        "examples": [
          {
            "title": "Secondary",
            "code": "<Button variant=\"secondary\">Secondary</Button>"
          },
          {
            "title": "Outline",
            "code": "<Button variant=\"outline\">Outline</Button>"
          },
          {
            "title": "Ghost",
            "code": "<Button variant=\"ghost\">Ghost</Button>"
          },
          {
            "title": "Destructive",
            "code": "<Button variant=\"destructive\">Destructive</Button>"
          },
          {
            "title": "Link",
            "code": "<Button variant=\"link\">Link</Button>"
          },
          {
            "title": "Soft",
            "code": "<Button variant=\"soft\" size=\"soft\">Request a demo</Button>"
          },
          {
            "title": "Soft Outline",
            "code": "<Button variant=\"soft-outline\" size=\"soft\">Join waitlist</Button>"
          }
        ]
      }
    },
